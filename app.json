{
  "expo": {
    "name": "RVX | Notes",
    "slug": "reviseit-3fm53g",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reviseit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0E0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reviseit"
    },
    "android": {
      "package": "com.reviseit",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground-padded.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "onnxruntime-react-native",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "MarkedBlockWidget",
              "label": "Marked Blocks",
              "description": "Displays your bookmarked revision blocks",
              "minWidth": "320dp",
              "minHeight": "120dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 3600000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "2703e46b-4da4-4446-8bcd-d9c24c40de0c"
      }
    },
    "owner": "rahul-varanasi"
  }
}